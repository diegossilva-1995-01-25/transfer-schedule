package br.com.diegossilva.app.service;

import org.springframework.security.core.userdetails.ClienteDetails;
import org.springframework.security.core.userdetails.UserDetailsService;
import org.springframework.security.core.userdetails.UsernameNotFoundException;
import org.springframework.stereotype.Service;

import br.com.diegossilva.app.entity.Cliente;
import br.com.diegossilva.app.repository.ClienteRepository;

@Service
public class DetalheCliente implements UserDetailsService {

	private final ClienteRepository repo;

	public DetalheCliente(ClienteRepository repo) {
		this.repo = repo;
	}
	
	@Override
	public UserDetails loadUserByUsername(String email) {
		Cliente c = repo.findById(email)
                .orElseThrow(() ->
                        new UsernameNotFoundException("Usuaário não encontrado: "+ email));
		
		return org.springframework.security.core.userdetails.Cliente.builder()
			.username(c.getCpf())
			.password(c.getSenha())
			.build();
	}
	
}
